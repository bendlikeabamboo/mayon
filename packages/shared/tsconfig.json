{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"declaration": true,
		"declarationMap": true,
		"rootDir": "src",
		"ignoreDeprecations": "6.0"
	},
	"include": ["src"]
}
