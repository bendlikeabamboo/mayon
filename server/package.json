		"better-sqlite3": "^12.11.1",
		"fastify": "^5.0.0"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@types/ws": "^8.5.0",
		"tsup": "^8.0.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"ws": "^8.0.0"
	}
}
