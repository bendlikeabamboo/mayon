{
	"name": "@mayon/server",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsup src/server.ts --format esm --target node22 --out-dir dist",
		"start": "node dist/server.js",
		"test": "vitest run"
	},
	"dependencies": {
		"@fastify/websocket": "^11.0.0",
