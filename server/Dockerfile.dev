# Dev image for the server — runs tsx watch inside the container.
# Source for HMR (server/src) and the @mayon/schema alias target are bind-mounted
# at runtime; node_modules and the built @mayon/shared dist are baked in.
# Rebuild with dev:build after dependency or shared-package changes.
FROM node:22-alpine

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.15.0 --activate

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY server/package.json server/
RUN pnpm install --frozen-lockfile --filter @mayon/server...

COPY packages/shared/ packages/shared/
RUN pnpm --filter @mayon/shared build
# Required by server/tsconfig.json path alias "@mayon/schema" -> "../src/lib/db/schema.ts"
COPY src/lib/db/schema.ts src/lib/db/schema.ts
COPY drizzle drizzle
COPY server server

EXPOSE 4319
CMD ["pnpm", "--filter", "@mayon/server", "dev"]
