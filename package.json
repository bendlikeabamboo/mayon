{
	"name": "mayon",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "Mayon — a local-first learning app built around a branchable chat graph.",
	"packageManager": "pnpm@10.15.0",
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"@sqlite.org/sqlite-wasm"
		]
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"tauri:icon": "tauri icon",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"bundle:migrations": "tsx src/lib/db/driver/bundle-migrations.ts"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^4.0.1",
		"@ai-sdk/google": "^4.0.2",
		"@ai-sdk/openai-compatible": "^3.0.2",
		"@fontsource/newsreader": "^5.2.10",
		"@sqlite.org/sqlite-wasm": "3.53.0-build1",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-dialog": "^2",
		"@tauri-apps/plugin-process": "^2",
		"@tauri-apps/plugin-sql": "^2.4.0",
		"@tauri-apps/plugin-updater": "^2",
		"ai": "^7.0.4",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hast-util-sanitize": "^5.0.2",
		"highlight.js": "^11.11.1",
		"katex": "0.16.11",
		"mermaid": "^11.16.0",
		"ollama-ai-provider-v2": "^3.6.0",
		"panzoom": "^9.4.4",
		"rehype-highlight": "^7.0.2",
		"rehype-katex": "^7.0.1",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"sql.js": "^1.14.1",
		"svelte": "^5.56.4",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"unified": "^11.0.5",
		"vite": "^8.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tailwindcss/vite": "^4.3.1",
		"@tauri-apps/cli": "^2.11.3",
		"@types/katex": "^0.16.8",
		"@types/node": "^26.0.1",
		"@types/sql.js": "^1.4.11",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.1",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	}
}
