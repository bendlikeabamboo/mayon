{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Mayon",
	"version": "0.0.1",
	"identifier": "com.mayon.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Mayon",
				"center": true,
				"width": 1280,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": true
			}
		],
		"security": {
			"csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:; frame-src 'self'"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxREUzQkVDMUQ4MjM4QjkKUldTNU9JSWQ3RHZlNFpISUxxSGNPdHkweGxGN1hFa3dSZ2xPWWxsUmh3bTd6a0dtWW9UKzZtbDEK",
			"endpoints": [
				"https://github.com/bendlikeabamboo/mayon/releases/latest/download/latest.json"
			]
		}
	},
	"bundle": {
		"active": true,
		"publisher": "Mayon",
		"category": "Education",
		"copyright": "© 2026 Mayon",
		"shortDescription": "Mayon — local-first learning app",
		"longDescription": "Mayon is a local-first learning app built around a branchable chat graph, with hands-on labs, quizzes, and offline AI providers.",
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"android": {
			"debugApplicationIdSuffix": ".debug"
		},
		"macOS": {
			"minimumSystemVersion": "10.15"
		},
		"windows": {
			"nsis": {
				"installMode": "currentUser"
			}
		},
		"linux": {
			"deb": {
				"depends": []
			}
		}
	}
}