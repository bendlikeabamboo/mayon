# Mayon local single-user defaults (P-pg-1 Postgres spike).
# Copy to .env and adjust credentials if needed. These are read by docker compose
# for variable substitution; the server consumes DATABASE_URL from its compose env.
# Postgres is reached only over the internal docker network (its port is never
# published to the host), and DATABASE_URL never enters the SPA bundle.

POSTGRES_USER=mayon
POSTGRES_PASSWORD=mayon
POSTGRES_DB=mayon
DATABASE_URL=postgres://mayon:mayon@db:5432/mayon
