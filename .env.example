# Mayon configuration defaults.
#
# These are read by docker compose for variable substitution. Copy to `.env`
# and adjust if needed. The server never reads this file directly — DATABASE_URL
# is always provided by the compose `environment:` block (the server reaches the
# database as `db:5432` on the internal docker network), so there is no host
# DATABASE_URL to set.

# Postgres credentials (used by both the db container and the server's DATABASE_URL).
POSTGRES_USER=mayon
POSTGRES_PASSWORD=mayon
POSTGRES_DB=mayon

# Pin a released image tag for the prod stack (e.g. 0.1.0). Defaults to `latest`.
# Used only by docker-compose.yml (prod). The dev stack builds from source.
MAYON_VERSION=latest
